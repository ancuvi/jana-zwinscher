---
import '../styles/global.css';
import { site as siteData } from '../site.config';
import manrope400Url from '../assets/fonts/manrope-400.woff2?url';
import instrumentSerifItalicUrl from '../assets/fonts/instrument-serif-400-italic.woff2?url';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

const {
  title = 'Jana Zwinzscher — Entrümpelung, Transporte & Endreinigung im Raum Mittweida',
  description = 'Schnell, sauber, persönlich. Entrümpelung, Haushaltsauflösung, Transporte und professionelle Endreinigung im Raum Mittweida, Frankenberg, Auerswalde und Chemnitz.',
  noindex = false,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const isPreview = Astro.site?.hostname.endsWith('github.io') ?? false;
const robotsContent = (noindex || isPreview) ? 'noindex, nofollow' : 'index, follow';
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(`${base}images/logo-og.png`, Astro.site).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'MovingCompany'],
  name: siteData.name,
  description,
  url: Astro.site?.toString(),
  image: ogImage,
  logo: new URL(`${base}images/logo-mark.png`, Astro.site).toString(),
  telephone: `+${siteData.whatsappNumber}`,
  email: siteData.email,
  priceRange: '€€',
  address: {
    '@type': 'PostalAddress',
    streetAddress: siteData.officeAddress.split(',')[0].trim(),
    addressLocality: siteData.location,
    postalCode: '09648',
    addressRegion: siteData.state,
    addressCountry: 'DE',
  },
  areaServed: siteData.serviceRegion.map((city) => ({
    '@type': 'City',
    name: city,
  })),
  serviceType: [
    'Entrümpelung',
    'Haushaltsauflösung',
    'Transporte',
    'Endreinigung',
    'Besenreine Übergabe',
  ],
  sameAs: [`https://wa.me/${siteData.whatsappNumber}`],
};
---

<!DOCTYPE html>
<html lang="de" data-palette="brand">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#2f8a83" />
    <meta name="robots" content={robotsContent} />
    <meta name="author" content={siteData.name} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg?v=2`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${base}favicon-32.png?v=2`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${base}apple-touch-icon.png?v=2`} />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>

    <link rel="preload" href={manrope400Url} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={instrumentSerifItalicUrl} as="font" type="font/woff2" crossorigin />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteData.name} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${siteData.name} — Reinigungsservice & Entrümpelung im Raum ${siteData.location}`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {!noindex && !isPreview && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body>
    <div class="scroll-progress" id="scrollProgress"></div>
    <div class="cursor-glow" id="cursorGlow"></div>

    <div class="cursor-broom" id="cursorBroom" aria-hidden="true">
      <svg viewBox="0 0 64 64" width="44" height="44" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="broomHandle" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#7a4a2a" />
            <stop offset="100%" stop-color="#5a3418" />
          </linearGradient>
          <linearGradient id="broomBristles" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#d9a35a" />
            <stop offset="60%" stop-color="#b8783a" />
            <stop offset="100%" stop-color="#8a4f1f" />
          </linearGradient>
        </defs>
        <g transform="rotate(-32 32 32)">
          <rect x="30" y="4" width="4" height="32" rx="2" fill="url(#broomHandle)" />
          <rect x="27" y="34" width="10" height="6" rx="1.5" fill="#3a2410" />
          <path d="M22 40 L42 40 L48 60 L16 60 Z" fill="url(#broomBristles)" />
          <path d="M24 42 L24 60 M28 42 L27 60 M32 42 L32 60 M36 42 L37 60 M40 42 L40 60"
                stroke="#5a3418" stroke-width="0.7" stroke-linecap="round" opacity="0.55" />
        </g>
      </svg>
    </div>

    <slot />

    <script>
      import '../scripts/site.ts';
    </script>
  </body>
</html>
