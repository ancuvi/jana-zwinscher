---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Jana Zwinscher — Entrümpelung, Transporte & Endreinigung im Raum Mittweida',
  description = 'Schnell, sauber, persönlich. Entrümpelung, Haushaltsauflösung, Transporte und professionelle Endreinigung im Raum Mittweida, Frankenberg, Auerswalde und Chemnitz.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="de" data-palette="forest">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#2a4a3a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Manrope:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="de_DE" />
  </head>
  <body>
    <div class="scroll-progress" id="scrollProgress"></div>
    <div class="cursor-glow" id="cursorGlow"></div>

    <slot />

    <script>
      import '../scripts/site.ts';
    </script>
  </body>
</html>
