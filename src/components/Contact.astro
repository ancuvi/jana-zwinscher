---
import { site, links } from '../site.config';

const inclusives = [
  'Kostenlose Besichtigung vor Ort',
  'Verbindlicher Festpreis — keine Überraschungen',
  'Fachgerechte Entsorgung & Trennung',
  'Besenreine Übergabe — auf Wunsch feinst geputzt',
  'Persönlich von mir betreut — keine Subunternehmer',
  'Fotodokumentation der Übergabe',
];

const checkSvg = `<svg viewBox="0 0 16 16"><path d="M3 8.5l3.2 3.2L13 4.8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>`;
---

<section id="kontakt" class="contact">
  <div class="section-header">
    <div class="section-num mono reveal"><span class="num">05</span> Kontakt aufnehmen</div>
    <h2 class="section-title reveal reveal-delay-1">
      Ein Anruf, eine Nachricht — <span class="it">Rückruf ab {site.callbackFrom}</span>.
    </h2>
  </div>

  <div class="contact-layout">
    <div class="contact-intro reveal">
      <h2>Lassen Sie uns <em>kurz reden</em>.</h2>
      <p>
        Am schnellsten erreichen Sie mich per Telefon oder WhatsApp. Wenn ich gerade nicht abnehmen kann (ich bin
        tagsüber im Gebäudemanagement) — kein Problem: ich rufe ab {site.callbackFrom} garantiert zurück.
      </p>

      <div class="contact-methods">
        <a href={links.tel} class="method">
          <span class="ico">
            <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M4 3h3l1.5 4-2 1.5a11 11 0 0 0 5 5L13 11.5 17 13v3a1 1 0 0 1-1 1A14 14 0 0 1 3 4a1 1 0 0 1 1-1z" stroke-linejoin="round"/></svg>
          </span>
          <div>
            <div class="lbl mono">Telefon</div>
            <div class="val">{site.phoneDisplay}</div>
          </div>
          <span class="badge">Mo–Sa</span>
        </a>

        <a href={links.whatsapp} class="method" rel="noopener" target="_blank">
          <span class="ico">
            <svg viewBox="0 0 24 24" class="filled" aria-hidden="true"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.4-.1-.6.1-.2.3-.7.9-.8 1-.1.2-.3.2-.6.1-.3-.1-1.2-.5-2.3-1.4-.9-.8-1.4-1.8-1.6-2.1-.2-.3 0-.4.1-.6.1-.1.3-.3.4-.5.1-.1.2-.3.3-.4.1-.2 0-.3 0-.5 0-.1-.6-1.5-.8-2-.2-.5-.4-.5-.6-.5h-.5c-.2 0-.5.1-.7.3-.3.3-1 1-1 2.4 0 1.4 1 2.8 1.2 3 .1.2 2.1 3.2 5 4.4.7.3 1.2.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.2.2-1.4-.1-.1-.3-.2-.5-.3zM12 22a10 10 0 0 1-5-1.3L1 22l1.5-5.4A10 10 0 1 1 12 22zm0-18.3a8.3 8.3 0 0 0-7 12.7l-.9 3.4 3.5-.9A8.3 8.3 0 1 0 12 3.7z"/></svg>
          </span>
          <div>
            <div class="lbl mono">WhatsApp</div>
            <div class="val">Sofort schreiben</div>
          </div>
          <span class="badge">am schnellsten</span>
        </a>

        <a href={links.mail} class="method">
          <span class="ico">
            <svg viewBox="0 0 20 20" aria-hidden="true"><rect x="2" y="4" width="16" height="12" rx="1"/><path d="m2 5 8 6 8-6"/></svg>
          </span>
          <div>
            <div class="lbl mono">E-Mail</div>
            <div class="val">{site.email}</div>
          </div>
        </a>
      </div>
    </div>

    <div class="availability-card reveal reveal-delay-1">
      <div class="avail-header">
        <span class="mono avail-eyebrow"><span class="live-dot"></span> Heute erreichbar</span>
        <h3>Rückruf <em>ab {site.callbackFrom}</em> — garantiert.</h3>
        <p>
          Tagsüber bin ich im Gebäudemanagement. Sie schreiben oder rufen wann es passt — ich melde mich verlässlich
          am späten Nachmittag zurück. Auch am Wochenende.
        </p>
      </div>

      <div class="clock-wrap">
        <svg class="clock" viewBox="0 0 200 200" aria-hidden="true">
          <circle cx="100" cy="100" r="92" fill="none" stroke="var(--line)" stroke-width="1"/>
          <path d="M 100 8 A 92 92 0 0 1 100 192" fill="none" stroke="color-mix(in oklab, var(--ink) 12%, transparent)" stroke-width="14" stroke-linecap="butt"/>
          <path d="M 100 192 A 92 92 0 1 1 100 8" fill="none" stroke="var(--brand)" stroke-width="14" stroke-linecap="butt" class="avail-arc"/>
          <g stroke="var(--ink)" stroke-width="1">
            <line x1="100" y1="14" x2="100" y2="22"/>
            <line x1="186" y1="100" x2="178" y2="100"/>
            <line x1="100" y1="186" x2="100" y2="178"/>
            <line x1="14" y1="100" x2="22" y2="100"/>
          </g>
          <text x="100" y="36" text-anchor="middle" font-family="JetBrains Mono" font-size="10" fill="var(--muted)">24</text>
          <text x="170" y="104" text-anchor="middle" font-family="JetBrains Mono" font-size="10" fill="var(--muted)">06</text>
          <text x="100" y="172" text-anchor="middle" font-family="JetBrains Mono" font-size="10" fill="var(--muted)">12</text>
          <text x="30" y="104" text-anchor="middle" font-family="JetBrains Mono" font-size="10" fill="var(--muted)">18</text>
          <circle cx="20.4" cy="146" r="6" fill="var(--accent)" class="now-marker"/>
          <text x="100" y="96" text-anchor="middle" font-family="Instrument Serif" font-style="italic" font-size="22" fill="var(--ink)">16:00</text>
          <text x="100" y="116" text-anchor="middle" font-family="JetBrains Mono" font-size="8" fill="var(--muted)" letter-spacing="2">RÜCKRUF AB</text>
        </svg>
        <div class="clock-legend">
          <span><i style="background:color-mix(in oklab, var(--ink) 12%, transparent)"></i> Hauptberuf</span>
          <span><i style="background:var(--brand)"></i> Für Sie erreichbar</span>
        </div>
      </div>

      <div class="inclusives">
        <div class="incl-title mono">In jedem Auftrag enthalten</div>
        <ul class="incl-list">
          {inclusives.map((item) => (
            <li>
              <Fragment set:html={checkSvg} />
              {item}
            </li>
          ))}
        </ul>
      </div>

      <a href={links.whatsapp} class="avail-cta" rel="noopener" target="_blank">
        <svg class="whatsapp-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.4-.1-.6.1-.2.3-.7.9-.8 1-.1.2-.3.2-.6.1-.3-.1-1.2-.5-2.3-1.4-.9-.8-1.4-1.8-1.6-2.1-.2-.3 0-.4.1-.6.1-.1.3-.3.4-.5.1-.1.2-.3.3-.4.1-.2 0-.3 0-.5 0-.1-.6-1.5-.8-2-.2-.5-.4-.5-.6-.5h-.5c-.2 0-.5.1-.7.3-.3.3-1 1-1 2.4 0 1.4 1 2.8 1.2 3 .1.2 2.1 3.2 5 4.4.7.3 1.2.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.2.2-1.4-.1-.1-.3-.2-.5-.3zM12 22a10 10 0 0 1-5-1.3L1 22l1.5-5.4A10 10 0 1 1 12 22zm0-18.3a8.3 8.3 0 0 0-7 12.7l-.9 3.4 3.5-.9A8.3 8.3 0 1 0 12 3.7z"/></svg>
        <span>Am schnellsten per WhatsApp — Antwort in der Regel innerhalb von 2 Stunden.</span>
        <svg class="arrow" width="18" height="14" viewBox="0 0 18 14" fill="none">
          <path d="M1 7h15M10 1l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>
