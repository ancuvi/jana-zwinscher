---
import { site } from '../site.config';
const base = import.meta.env.BASE_URL;
---

<nav class="top" id="topnav">
  <a href="#top" class="brand" aria-label={`${site.name} — Startseite`}>
    <img class="mark" src={`${base}images/logo-mark.svg?v=2`} alt="" width="34" height="34" />
    <span class="brand-name">{site.name} <span class="sub">— {site.location}</span></span>
  </a>
  <div class="nav-links">
    <a href="#leistungen">Leistungen</a>
    <a href="#ueber">Über Jana</a>
    <a href="#region">Einzugsgebiet</a>
    <a href="#ablauf">Ablauf</a>
  </div>
  <a href="#kontakt" class="nav-cta">
    <span class="dot"></span>
    Termin anfragen
  </a>
</nav>
