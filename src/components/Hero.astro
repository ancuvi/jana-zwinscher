---
import { site, links } from '../site.config';
---

<header class="hero" id="top">
  <div class="hero-decoration" aria-hidden="true">
    <svg viewBox="0 0 480 480">
      <g class="ring">
        <circle cx="240" cy="240" r="200" fill="none" stroke="var(--brand)" stroke-width=".5" stroke-dasharray="2 6"/>
        <circle cx="240" cy="240" r="160" fill="none" stroke="var(--brand)" stroke-width=".5" stroke-dasharray="3 8"/>
        <circle cx="240" cy="240" r="120" fill="none" stroke="var(--brand)" stroke-width=".5"/>
      </g>
      <text x="240" y="246" text-anchor="middle" font-family="Instrument Serif" font-style="italic" font-size="22" fill="var(--brand)" opacity=".5">{site.location} · {site.radiusKm} km</text>
    </svg>
  </div>

  <div class="hero-main">
    <div class="hero-eyebrow mono">
      <span class="line"></span>
      <span>{site.tagline}</span>
    </div>

    <h1 class="hero-title" id="heroTitle">
      <span class="word"><span class="italic" style="animation-delay:.05s">Sauber</span></span>
      <span class="word"><span style="animation-delay:.12s">gemacht.</span></span>
      <br />
      <span class="word"><span style="animation-delay:.19s">Zuverlässig</span></span>
      <span class="word"><span class="italic" style="animation-delay:.26s">geräumt.</span></span>
    </h1>

    <p class="hero-lead">
      Persönlich, schnell, gründlich. Wir räumen Häuser, Wohnungen und Nachlässe —
      <em class="serif" style="color:var(--brand)">mit Wertanrechnung, Pauschalpreis und besenreiner Übergabe.</em>
      Auch kurzfristig — als kleines Familienunternehmen mit Profi-Erfahrung aus dem Gebäudemanagement.
    </p>

    <div class="hero-ctas">
      <a href="#kontakt" class="btn-primary">
        Kostenlos anfragen
        <svg class="arrow" width="18" height="14" viewBox="0 0 18 14" fill="none">
          <path d="M1 7h15M10 1l6 6-6 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href={links.whatsapp} class="btn-ghost" rel="noopener" target="_blank">
        <svg class="whatsapp-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.4-.1-.6.1-.2.3-.7.9-.8 1-.1.2-.3.2-.6.1-.3-.1-1.2-.5-2.3-1.4-.9-.8-1.4-1.8-1.6-2.1-.2-.3 0-.4.1-.6.1-.1.3-.3.4-.5.1-.1.2-.3.3-.4.1-.2 0-.3 0-.5 0-.1-.6-1.5-.8-2-.2-.5-.4-.5-.6-.5h-.5c-.2 0-.5.1-.7.3-.3.3-1 1-1 2.4 0 1.4 1 2.8 1.2 3 .1.2 2.1 3.2 5 4.4.7.3 1.2.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.2.2-1.4-.1-.1-.3-.2-.5-.3zM12 22a10 10 0 0 1-5-1.3L1 22l1.5-5.4A10 10 0 1 1 12 22zm0-18.3a8.3 8.3 0 0 0-7 12.7l-.9 3.4 3.5-.9A8.3 8.3 0 1 0 12 3.7z"/></svg>
        WhatsApp schreiben
      </a>
    </div>
  </div>

  <aside class="hero-side">
    <div class="info-card">
      <span class="label mono">Heute erreichbar</span>
      <div class="value">Rückruf <strong>ab {site.callbackFrom}</strong> garantiert — auch am Wochenende.</div>
    </div>
    <div class="quick-row">
      <div class="info-card">
        <span class="label mono">Einzugsgebiet</span>
        <div class="value">{site.location} + <strong>{site.radiusKm} km</strong></div>
      </div>
      <div class="info-card">
        <span class="label mono">Wertanrechnung</span>
        <div class="value">Brauchbares wird <strong>angerechnet</strong></div>
      </div>
    </div>
  </aside>
</header>
