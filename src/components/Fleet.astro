---
// Astro optimiert Bilder aus src/assets/ automatisch — Format, Größe und Lazy-Loading
// werden beim Build erzeugt. Weitere Bilder hier importieren.
import { Image } from 'astro:assets';
import fuhrparkImage from '../assets/fuhrpark.png';

const fleetAlt = 'Zwei weiße Transporter mit Aufschrift "Räumung, Haushaltsauflösung & Reinigungsservice" nebeneinander geparkt im Abendlicht — der Fuhrpark von Jana Zwinzscher.';
---

<section id="fuhrpark" class="fleet">
  <div class="section-header">
    <div class="section-num mono reveal"><span class="num">03</span> Mein Fuhrpark</div>
    <h2 class="section-title reveal reveal-delay-1">
      Eigene Fahrzeuge — <span class="it">immer einsatzbereit</span>, ohne Wartezeit.
    </h2>
  </div>

  <div class="fleet-grid">
    <aside class="fleet-text reveal">
      <p class="lead">
        Vom kompakten Möbeltransport bis zur kompletten Wohnungsauflösung — meine eigenen Fahrzeuge
        stehen bereit. Keine Mietwagen-Termine, keine Wartezeiten: Wenn Sie anrufen, kann ich los.
      </p>
      <ul class="fleet-points">
        <li><span class="mono">●</span> Genug Ladevolumen für Haushaltsauflösungen</li>
        <li><span class="mono">●</span> Sauber gepflegt — auch innen</li>
        <li><span class="mono">●</span> Versichert und angemeldet im Raum Mittweida</li>
      </ul>
      <div class="fleet-quote">
        "Mein Werkzeug fährt mit. Nichts wird im letzten Moment organisiert."
      </div>
    </aside>

    <figure class="fleet-photo reveal reveal-delay-1">
      <div class="fleet-stamp">Immer<br />einsatz-<br />bereit</div>
      <Image
        src={fuhrparkImage}
        alt={fleetAlt}
        widths={[480, 800, 1200, 1600]}
        sizes="(max-width: 900px) 100vw, 60vw"
        format="webp"
        quality={75}
        loading="lazy"
        decoding="async"
      />
      <figcaption class="fleet-caption mono">
        <span class="dot">●</span> Eigener Fuhrpark — Raum Mittweida
      </figcaption>
    </figure>
  </div>
</section>
